# ── Fondly Web — copy to .env.local and fill in to enable "live mode" ─────────
# When any of these are missing the app runs in seed mode (local data/app.ts),
# so the design demo works with no backend.

# Fondly API base URL (note the /api suffix)
VITE_API_URL=http://localhost:8000/api

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key
